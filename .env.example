# ╔══════════════════════════════════════════════════════════════╗
# ║  OMNICANAL · variables de entorno (plantilla)                  ║
# ║  Copia a .env (local) o configúralas en Railway → Variables.   ║
# ║  NO subas el .env real con credenciales a GitHub.              ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Odoo (ERP / inventario) ────────────────────────────────────
ODOO_URL=https://tu-instancia.odoo.com
ODOO_DB=tu_db
ODOO_USER=usuario@dominio.com
ODOO_PASSWORD=

# ── WooCommerce (centro / vista GENERAL) ───────────────────────
WC_URL=https://tu-tienda.com
WC_CONSUMER_KEY=ck_xxx
WC_CONSUMER_SECRET=cs_xxx

# ── WordPress (subida de medios) ───────────────────────────────
WP_USER=
WP_APP_PASSWORD=

# ── IA ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
REPLICATE_API_KEY=
SERPAPI_KEY=

# ── Base de datos MySQL (cache híbrido ML / Amazon) ────────────
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── Mercado Libre ──────────────────────────────────────────────
ML_SITE_ID=MLM

# ── App ────────────────────────────────────────────────────────
APP_ENV=production
# Orígenes permitidos (frontend). Coma-separados.
CORS_ORIGINS=http://localhost:3000,https://tu-frontend.up.railway.app
